%pip install textblob


from textblob import TextBlob

def get_grammar_score(text):
    blob = TextBlob(text)
    corrected = str(blob.correct())

    original_words = text.split()
    corrected_words = corrected.split()

    # count differences
    error_count = sum(
        1 for o, c in zip(original_words, corrected_words) if o != c
    )

    # simple scoring
    if error_count == 0:
        score = 10
    elif error_count <= 2:
        score = 8
    elif error_count <= 5:
        score = 6
    else:
        score = 4

    return score

    #NLP answer analyser using NLTK.
import nltk
from nltk.tokenize import word_tokenize, sent_tokenize
from nltk.corpus import stopwords

def analyze_text_nltk(text):
    
    grammar_score = get_grammar_score(text)

    text = text.lower()

    # TOKENIZATION 
    words = word_tokenize(text)
    sentences = sent_tokenize(text)

    word_count = len(words)
    num_sentences = len(sentences)

    avg_sentence_length = word_count / num_sentences if num_sentences else 0

    #STOPWORD REMOVAL
    stop_words = set(stopwords.words('english'))
    filtered_words = [w for w in words if w.isalnum() and w not in stop_words]

    #KEYWORD RELEVANCE Checking
    keywords = ["python", "data", "analysis", "machine", "learning", "model", "algorithm"]
    keyword_score = sum(1 for word in filtered_words if word in keywords)

    #POS TAGGING (QUALITY SIGNAL)
    pos_tags = nltk.pos_tag(words)

    # Count nouns & verbs (important for meaningful answers)
    noun_count = sum(1 for word, tag in pos_tags if tag.startswith('NN'))
    verb_count = sum(1 for word, tag in pos_tags if tag.startswith('VB'))

    #FILLER WORDS
    fillers = ["um", "uh", "like", "ahm", "ahh", "you know", "basically"]
    filler_count = sum(text.count(f) for f in fillers)

    #CLARITY SCORE
    if avg_sentence_length < 5:
        clarity_score = 4
    elif avg_sentence_length <= 20:
        clarity_score = 10
    else:
        clarity_score = 6

    return {
        "grammar_score":grammar_score,
        "word_count": word_count,
        "num_sentences": num_sentences,
        "avg_sentence_length": round(avg_sentence_length, 2),
        "keyword_score": keyword_score,
        "noun_count": noun_count,
        "verb_count": verb_count,
        "filler_count": filler_count,
        "clarity_score": clarity_score
    }

    #Emotion Detection
def detect_emotion(text):
    text_lower = text.lower()
    words = text.split()

    word_count = len(words)

    # ----------- FILLER WORDS -----------
    fillers = ["um", "uh", "like", "you know", "basically"]
    filler_count = sum(text_lower.count(f) for f in fillers)

    # ----------- CONFIDENCE WORDS -----------
    confident_phrases = [
        "i am confident", "i can", "i will", "i have",
        "i believe", "i am sure", "i am capable"
    ]
    confidence_hits = sum(1 for p in confident_phrases if p in text_lower)

    # ----------- REPETITION CHECK -----------
    repeated_words = sum(
        1 for i in range(1, len(words)) if words[i].lower() == words[i-1].lower()
    )

    # ----------- SCORING -----------
    confidence_score = confidence_hits * 2 + (word_count / 10)
    nervous_score = filler_count * 2 + repeated_words

    # ----------- DECISION LOGIC -----------

    if nervous_score >= 3:
        return "nervous"

    elif confidence_score >= 3 and filler_count == 0:
        return "confident"

    else:
        return "neutral"

        #Answer Quality Score
def calculate_answer_quality(nlp_result):
    keyword_score = nlp_result["keyword_score"]  # already scaled 0–10
    word_count = nlp_result["word_count"]

    # Depth bonus
    if word_count > 30:
        depth_bonus = 2
    elif word_count > 20:
        depth_bonus = 1
    else:
        depth_bonus = 0

    score = min(keyword_score + depth_bonus, 10)

    return round(score, 2)

    #Communication Score
def calculate_communication(nlp_result):
    avg_len = nlp_result["avg_sentence_length"]
    grammar = nlp_result["grammar_score"]

    # Sentence structure
    if avg_len < 5:
        structure_score = 4
    elif avg_len <= 20:
        structure_score = 10
    else:
        structure_score = 6

    # Grammar low weight
    final = (structure_score * 0.7) + (grammar * 0.3)

    return round(final, 2)


    #CONFIDENCE SCORE (from Emotion detection module)
def calculate_confidence(emotion):
    if emotion == "confident":
        return 9
    elif emotion == "neutral":
        return 6
    else:  # nervous
        return 3

        #Final Score(Based on the above three)
def calculate_final_score(nlp_result, emotion):
    answer_quality = calculate_answer_quality(nlp_result)
    communication = calculate_communication(nlp_result)
    confidence = calculate_confidence(emotion)

    final_score = (
        answer_quality * 0.5 +
        communication * 0.2 +
        confidence * 0.3
    )

    return {
        "answer_quality": answer_quality,
        "communication": communication,
        "confidence": confidence,
        "final_score": round(final_score, 2)
    }

